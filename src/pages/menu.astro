							)}
						</div>
					))}
				</div>
			</section>

			<section id="rind" class="category-section">
				<h2 class="category-title">Rind (36-39)</h2>
				<div class="menu-grid">
					{rind.map((item) => (
						<div class="menu-item">
							<div class="item-header">
								<span class="item-number">{item.number}</span>
								<h3 class="item-name">
									<span class="name-german">{item.name_german}</span>
									<span class="name-chinese">{item.name_chinese}</span>
								</h3>
								<span class="item-price">€{item.price}</span>
							</div>

							{item.description && (
								<p class="item-description">{item.description}</p>
							)}

							{item.allergens && (
								<p class="item-allergens">Allergens: {item.allergens}</p>
							)}
						</div>
					))}
				</div>
			</section>

			<section id="lamm" class="category-section">
				<h2 class="category-title">Lamm (36-39)</h2>
				<div class="menu-grid">
					{lamm.map((item) => (
						<div class="menu-item">
							<div class="item-header">
								<span class="item-number">{item.number}</span>
								<h3 class="item-name">
									<span class="name-german">{item.name_german}</span>
									<span class="name-chinese">{item.name_chinese}</span>
								</h3>
								<span class="item-price">€{item.price}</span>
							</div>

							{item.description && (
								<p class="item-description">{item.description}</p>
							)}

							{item.allergens && (
								<p class="item-allergens">Allergens: {item.allergens}</p>
							)}
						</div>
					))}
				</div>
			</section>

			<!-- Getränke Section -->
			<section id="getränke" class="category-section">
				<h2 class="category-title">Getränke</h2>
				<div class="menu-grid">
					{getränke.map((item) => (
						<div class="menu-item">
							<div class="item-header">
								<span class="item-number">{item.number}</span>
								<h3 class="item-name">
									<span class="name-german">{item.name_german}</span>
									<span class="name-chinese">{item.name_chinese}</span>
								</h3>
								<span class="item-price">€{item.price}</span>
							</div>

							{item.description && (
								<p class="item-description">{item.description}</p>
							)}

							{item.allergens && (
								<p class="item-allergens">Allergens: {item.allergens}</p>
							)}
							
							{item.additive && (
								<p class="item-additive">Additive: {item.additive}</p>
							)}
						</div>
					))}
				</div>
			</section>

			<!-- Bier & Wein Section -->
			<section id="bierAndWein" class="category-section">
				<h2 class="category-title">Bier & Wein</h2>
				<div class="menu-grid">
					{bierAndWein.map((item) => (
						<div class="menu-item">
							<div class="item-header">
								<span class="item-number">{item.number}</span>
								<h3 class="item-name">
									<span class="name-german">{item.name_german}</span>
									<span class="name-chinese">{item.name_chinese}</span>
								</h3>
