---
import Layout from '../layouts/Layout.astro';
import { mittagsmenü } from '../data/menu/mittagsmenu';
---

<Layout>
	<div id="menu-container">
		<div id="menu-header">
			<h1>Mittagsmenü</h1>
			<p class="subtitle">12:00 - 15:00Uhr</p>
            <p>Zu jedem Gericht: Sauer-Scharf-Suppe als Vorspeise & Reis zum Hauptgang.</p>
		</div>

		<div id="menu-content">
			<div class="menu-grid">
				{mittagsmenü.map((item) => (
					<div class="menu-item">
						<div class="item-header">
							<span class="item-number">{item.number}</span>
							<h2 class="item-name">
								<span class="name-german">{item.name_german}</span>
								<span class="name-chinese">{item.name_chinese}</span>
							</h2>
							<span class="item-price">€{item.price}</span>
						</div>
						
						{item.description && (
							<p class="item-description">{item.description}</p>
						)}
						
						{item.allergens && (
							<p class="item-allergens">Allergens: {item.allergens}</p>
						)}
					</div>
				))}
			</div>
		</div>

		<div id="menu-footer">
			
		</div>
	</div>
</Layout>

<style>
	#menu-container {
		font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
		max-width: 1200px;
		margin: 0 auto;
		padding: 40px 20px;
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(240, 240, 240, 0.98) 100%);
		min-height: 100vh;
	}

	#menu-header {
		text-align: center;
		margin-bottom: 40px;
		border-bottom: 3px solid #d4af37;
		padding-bottom: 20px;
	}

	#menu-header h1 {
		margin: 0;
		font-size: 2.5em;
		color: #222;
		font-weight: 700;
		letter-spacing: 1px;
	}

	.subtitle {
		margin: 10px 0 0 0;
		color: #666;
		font-size: 1em;
		font-weight: 400;
	}

	.menu-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 20px;
		margin-bottom: 40px;
	}

	.menu-item {
		background: white;
		border: 1px solid #e0e0e0;
		border-radius: 8px;
		padding: 20px;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
		transition: all 0.3s ease;
	}

	.menu-item:hover {
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
		border-color: #d4af37;
		transform: translateY(-2px);
	}

	.item-header {
		display: flex;
		align-items: flex-start;
		gap: 12px;
		margin-bottom: 12px;
	}

	.item-number {
		background: #d4af37;
		color: white;
		padding: 6px 12px;
		border-radius: 4px;
		font-weight: 700;
		font-size: 0.9em;
		flex-shrink: 0;
		min-width: 40px;
		text-align: center;
	}

	.item-name {
		margin: 0;
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.name-german {
		display: block;
		font-size: 1.1em;
		color: #222;
		font-weight: 600;
	}

	.name-chinese {
		display: block;
		font-size: 1em;
		color: #555;
		font-weight: 400;
	}

	.item-price {
		font-size: 1.3em;
		font-weight: 700;
		color: #d4af37;
		flex-shrink: 0;
	}

	.item-description {
		margin: 12px 0 8px 0;
		color: #555;
		font-size: 0.9em;
		line-height: 1.5;
	}

	.item-allergens {
		margin: 8px 0 0 0;
		color: #999;
		font-size: 0.85em;
		font-style: italic;
	}

	#menu-footer {
		text-align: center;
		padding-top: 30px;
		border-top: 2px solid #d4af37;
		color: #666;
		font-size: 0.95em;
	}

	#menu-footer p {
		margin: 8px 0;
	}

	@media (max-width: 768px) {
		#menu-container {
			padding: 20px 15px;
		}

		#menu-header h1 {
			font-size: 2em;
		}

		.menu-grid {
			grid-template-columns: 1fr;
			gap: 15px;
		}

		.item-header {
			flex-wrap: wrap;
		}

		.item-name {
			flex-basis: 100%;
		}
	}
</style>
