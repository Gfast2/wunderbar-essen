---
import Layout from '../layouts/Layout.astro';
import { mittagsmenü } from '../data/menu/mittagsmenu';
import { gemüse } from '../data/menu/gemüse';
import { desert } from '../data/menu/desert';
import { reiseAndNudeln } from '../data/menu/reiseAndNudeln';
import { meeresfrüchte } from '../data/menu/meeresfrüchte';
import { schwein } from '../data/menu/schwein';
import { dimsum } from '../data/menu/dimsum';
import { vorspeise } from '../data/menu/vorspeise';
import { suppen } from '../data/menu/suppen';
import { huhnAndEnte } from '../data/menu/huhnAndEnte';
import { rind } from '../data/menu/rind';
import { lamm } from '../data/menu/lamm';
import { getränke } from '../data/menu/getränke';
import { bierAndWein } from '../data/menu/bierAndWein';
---

<Layout>
	<div id="menu-container">
		<div id="menu-header">
			<h1>Menü</h1>
			<div id="filter-tags">
				<button class="filter-tag active" data-category="mittagsmenu">Mittagsmenü</button>
				<button class="filter-tag" data-category="gemuese">Gemüse</button>
				<button class="filter-tag" data-category="desert">Dessert</button>
				<button class="filter-tag" data-category="reiseAndNudeln">Reis & Nudeln</button>
				<button class="filter-tag" data-category="meeresfrüchte">Meeresfrüchte</button>
				<button class="filter-tag" data-category="schwein">Schwein</button>
				<button class="filter-tag" data-category="dimsum">Dim Sum</button>
				<button class="filter-tag" data-category="vorspeise">Vorspeise</button>
				<button class="filter-tag" data-category="suppen">Suppen</button>
				<button class="filter-tag" data-category="huhnAndEnte">Hühn & Ente</button>
				<button class="filter-tag" data-category="rind">Rind</button>
				<button class="filter-tag" data-category="lamm">Lamm</button>
				<button class="filter-tag" data-category="getränke">Getränke</button>
				<button class="filter-tag" data-category="bierAndWein">Bier & Wein</button>
			</div>
		</div>

		<div id="menu-content">
			<!-- Mittagsmenü Section -->
			<section id="mittagsmenu" class="category-section">
				<h2 class="category-title">Mittagsmenü (H1-H12)</h2>
				<p class="subtitle">(12:00 - 15:00 Uhr) Zu jedem Gericht: Sauer-Scharf-Suppe als Vorspeise & Reis zum Hauptgang.</p>
				<div class="menu-grid">
					{mittagsmenü.map((item) => (
						<div class="menu-item">
							<div class="item-header">
								<span class="item-number">{item.number}</span>
								<h3 class="item-name">
									<span class="name-german">{item.name_german}</span>
									<span class="name-chinese">{item.name_chinese}</span>
								</h3>
								<span class="item-price">€{item.price}</span>
							</div>
							
							{item.description && (
								<p class="item-description">{item.description}</p>
							)}
							
							{item.allergens && (
								<p class="item-allergens">Allergens: {item.allergens}</p>
							)}
						</div>
					))}
				</div>
			</section>

			<!-- Gemüse Section -->
			<section id="gemuese" class="category-section">
				<h2 class="category-title">Gemüse (59-73)</h2>
				<div class="menu-grid">
					{gemüse.map((item) => (
						<div class="menu-item">
							<div class="item-header">
								<span class="item-number">{item.number}</span>
								<h3 class="item-name">
									<span class="name-german">{item.name_german}</span>
									<span class="name-chinese">{item.name_chinese}</span>
								</h3>
								<span class="item-price">€{item.price}</span>
							</div>
							
							{item.description && (
								<p class="item-description">{item.description}</p>
							)}
							
							{item.allergens && (
								<p class="item-allergens">Allergens: {item.allergens}</p>
							)}
						</div>
					))}
				</div>
			</section>

			<!-- Dessert Section -->
			<section id="desert" class="category-section">
				<h2 class="category-title">Dessert (82-85)</h2>
				<div class="menu-grid">
					{desert.map((item) => (
						<div class="menu-item">
							<div class="item-header">
								<span class="item-number">{item.number}</span>
