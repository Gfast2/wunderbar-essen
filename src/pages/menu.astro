					))}
				</div>
			</section>
		</div>

		<div id="menu-footer">
			
		</div>

		<button id="back-to-top" aria-label="Back to top">↑</button>
	</div>

	<script>
		// Filter tag navigation
		document.querySelectorAll('.filter-tag').forEach(button => {
			button.addEventListener('click', function() {
				const category = this.getAttribute('data-category');
				
				// Update active state
				document.querySelectorAll('.filter-tag').forEach(btn => {
					btn.classList.remove('active');
				});
				this.classList.add('active');
				
				// Scroll to section
				const section = document.getElementById(category);
				if (section) {
					section.scrollIntoView({ behavior: 'smooth', block: 'start' });
				}
			});
		});

		// Back to top button
		const backToTopBtn = document.getElementById('back-to-top');
		
		window.addEventListener('scroll', function() {
			if (window.pageYOffset > 300) {
				backToTopBtn.classList.add('visible');
			} else {
				backToTopBtn.classList.remove('visible');
			}
		});

		backToTopBtn.addEventListener('click', function() {
			window.scrollTo({ top: 0, behavior: 'smooth' });
		});
	</script>
</Layout>

<style>
	#menu-container {
		font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
		max-width: 1200px;
		margin: 0 auto;
		padding: 40px 20px;
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(240, 240, 240, 0.98) 100%);
		min-height: 100vh;
	}

	#menu-header {
		text-align: center;
		margin-bottom: 40px;
		border-bottom: 3px solid #d4af37;
		padding-bottom: 20px;
	}

	#menu-header h1 {
		margin: 0;
		font-size: 2.5em;
		color: #222;
		font-weight: 700;
		letter-spacing: 1px;
	}

	.subtitle {
		margin: 10px 0 0 0;
		color: #666;
		font-size: 1em;
		font-weight: 400;
		margin-bottom: 20px;
	}

	.menu-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 20px;
		margin-bottom: 40px;
	}

	.menu-item {
		background: white;
		border: 1px solid #e0e0e0;
		border-radius: 8px;
		padding: 20px;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
		transition: all 0.3s ease;
	}

	.menu-item:hover {
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
		border-color: #d4af37;
		transform: translateY(-2px);
	}

	.item-header {
		display: flex;
		align-items: flex-start;
		gap: 12px;
		margin-bottom: 12px;
	}

	.item-number {
		background: #d4af37;
		color: white;
		padding: 6px 12px;
		border-radius: 4px;
		font-weight: 700;
		font-size: 0.9em;
		flex-shrink: 0;
		min-width: 40px;
		text-align: center;
	}

	.item-name {
		margin: 0;
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.name-german {
		display: block;
		font-size: 1.1em;
		color: #222;
		font-weight: 600;
	}

	.name-chinese {
		display: block;
		font-size: 1em;
		color: #555;
		font-weight: 400;
	}

	.item-price {
		font-size: 1.3em;
		font-weight: 700;
		color: #d4af37;
		flex-shrink: 0;
	}

	.item-description {
		margin: 12px 0 8px 0;
		color: #555;
		font-size: 0.9em;
		line-height: 1.5;
	}

	.item-allergens {
		margin: 8px 0 0 0;
		color: #999;
		font-size: 0.85em;
		font-style: italic;
	}
	.item-additive {
		margin: 8px 0 0 0;
		color: #999;
		font-size: 0.85em;
		font-style: italic;
	}

	#menu-footer {
		text-align: center;
		padding-top: 30px;
		border-top: 2px solid #d4af37;
		color: #666;
		font-size: 0.95em;
	}

	#menu-footer p {
		margin: 8px 0;
	}

	#filter-tags {
		display: flex;
		justify-content: center;
		gap: 12px;
		margin-top: 20px;
		flex-wrap: wrap;
	}

	.filter-tag {
		padding: 10px 24px;
		border: 2px solid #d4af37;
		background: transparent;
		color: #d4af37;
		font-size: 1em;
		font-weight: 600;
		border-radius: 24px;
		cursor: pointer;
		transition: all 0.3s ease;
	}

	.filter-tag:hover {
		background: rgba(212, 175, 55, 0.1);
		transform: scale(1.05);
	}

	.filter-tag.active {
		background: #d4af37;
		color: white;
		box-shadow: 0 4px 12px rgba(212, 175, 55, 0.3);
	}

	.category-section {
		margin-bottom: 60px;
		scroll-margin-top: 40px;
	}

	.category-title {
		font-size: 1.8em;
		color: #222;
		font-weight: 700;
		margin: 0 0 30px 0;
		padding-bottom: 15px;
		border-bottom: 2px solid #d4af37;
	}

	#back-to-top {
		position: fixed;
		bottom: 30px;
		right: 30px;
		width: 50px;
		height: 50px;
		background: #d4af37;
		color: white;
		border: none;
		border-radius: 50%;
		font-size: 1.5em;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		visibility: hidden;
		transition: all 0.3s ease;
		box-shadow: 0 4px 12px rgba(212, 175, 55, 0.3);
		z-index: 100;
	}

	#back-to-top:hover {
		background: #c99a2a;
		box-shadow: 0 6px 16px rgba(212, 175, 55, 0.4);
		transform: translateY(-3px);
	}

	#back-to-top.visible {
		opacity: 1;
		visibility: visible;
	}

	@media (max-width: 768px) {
		#menu-container {
			padding: 20px 15px;
		}

		#menu-header h1 {
			font-size: 2em;
		}

		.menu-grid {
			grid-template-columns: 1fr;
			gap: 15px;
		}

		.item-header {
			flex-wrap: wrap;
		}

		.item-name {
			flex-basis: 100%;
		}
	}
</style>
