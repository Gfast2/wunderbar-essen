							)}
							
							{item.allergens && (
								<p class="item-allergens">Allergens: {item.allergens}</p>
							)}
						</div>
					))}
				</div>
			</section>

			<!-- dimsum Section -->
			<section id="dimsum" class="category-section">
				<h2 class="category-title">Dim Sum (11-20)</h2>
				<div class="menu-grid">
					{dimsum.map((item) => (
						<div class="menu-item">
							<div class="item-header">
								<span class="item-number">{item.number}</span>
								<h3 class="item-name">
									<span class="name-german">{item.name_german}</span>
									<span class="name-chinese">{item.name_chinese}</span>
								</h3>
								<span class="item-price">€{item.price}</span>
							</div>

							{item.description && (
								<p class="item-description">{item.description}</p>
							)}

							{item.allergens && (
								<p class="item-allergens">Allergens: {item.allergens}</p>
							)}
						</div>
					))}
				</div>
			</section>
			
			<!-- vorspeise Section -->
			<section id="vorspeise" class="category-section">
				<h2 class="category-title">Vorspeise (1-10)</h2>
				<div class="menu-grid">
					{vorspeise.map((item) => (
						<div class="menu-item">
							<div class="item-header">
								<span class="item-number">{item.number}</span>
								<h3 class="item-name">
									<span class="name-german">{item.name_german}</span>
									<span class="name-chinese">{item.name_chinese}</span>
								</h3>
								<span class="item-price">€{item.price}</span>
							</div>

							{item.description && (
								<p class="item-description">{item.description}</p>
							)}

							{item.allergens && (
								<p class="item-allergens">Allergens: {item.allergens}</p>
							)}
						</div>
					))}
				</div>
			</section>

			<!-- suppen Section -->
			<section id="suppen" class="category-section">
				<h2 class="category-title">Suppen (11-20)</h2>
				<div class="menu-grid">
					{suppen.map((item) => (
						<div class="menu-item">
							<div class="item-header">
								<span class="item-number">{item.number}</span>
								<h3 class="item-name">
									<span class="name-german">{item.name_german}</span>
									<span class="name-chinese">{item.name_chinese}</span>
								</h3>
								<span class="item-price">€{item.price}</span>
							</div>

							{item.description && (
