---
import type { Menu } from '../../content.config';
import { translateAllergens } from '../utils/allergenTranslator';
import { translateAdditives } from '../utils/additiveTranslator';

interface Props {
	sectionId: string;
	title: string;
	subtitle?: string;
	items: Menu[];
}

const { sectionId, title, subtitle, items } = Astro.props;
---

<section id={sectionId} class="category-section">
	<h2 class="category-title">{title}</h2>
	{subtitle && (
		<p class="subtitle">{subtitle}</p>
	)}
	<div class="menu-grid">
		{items.map((item) => (
			<div class="menu-item" {...(item.photo && { 'data-photo': item.photo })}>
				<div class="item-header">
					<span class="item-number">{item.number}</span>
					<h3 class="item-name">
						<span class="name-german">{item.name_german}</span>
						<span class="name-chinese">{item.name_chinese}</span>
					</h3>
					<span class="item-price">€{item.price}</span>
				</div>

				{item.description && (
					<p class="item-description">{item.description}</p>
				)}

				{item.allergens && (
					<p class="item-allergens">Allergens: {translateAllergens(item.allergens)}</p>
				)}

				{item.additive && (
					<p class="item-additive">Additive: {translateAdditives(item.additive)}</p>
				)}
				{item.photo && <span class="photo-ribbon">Foto</span>}
			</div>
		))}
	</div>
</section>
